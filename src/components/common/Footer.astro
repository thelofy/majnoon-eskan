---
import type { Locale } from '@/i18n/types';
import { getDictionary } from '@/i18n/utils';
import Icon from '@/components/icons/Icon.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);
const base = `/${locale}`;
const year = new Date().getFullYear();
---

<footer class="mt-0 border-t border-white/[0.06] bg-eskan-surface text-eskan-ivory">
  <div class="editorial-container py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <p class="font-display text-2xl font-semibold">{t.siteName}</p>
        <p class="mt-3 text-sm text-white/60">{t.siteTagline}</p>
        <p class="mt-4 text-sm text-white/50">{t.contact.address}</p>
      </div>

      <div>
        <p class="text-xs font-medium uppercase tracking-luxury text-gold-muted">{t.footer.quickLinks}</p>
        <ul class="mt-5 space-y-3">
          <li><a href={`${base}/projects`} class="text-sm text-white/70 transition-colors hover:text-gold-muted">{t.nav.projects}</a></li>
          <li><a href={`${base}/capabilities`} class="text-sm text-white/70 transition-colors hover:text-gold-muted">{t.nav.capabilities}</a></li>
          <li><a href={`${base}/special-works`} class="text-sm text-white/70 transition-colors hover:text-gold-muted">{t.nav.specialWorks}</a></li>
          <li><a href={`${base}/contact`} class="text-sm text-white/70 transition-colors hover:text-gold-muted">{t.nav.contact}</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs font-medium uppercase tracking-luxury text-gold-muted">{t.footer.followUs}</p>
        <a
          href="https://www.instagram.com/sangeskan"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram @sangeskan"
          class="mt-5 inline-flex items-center gap-2.5 rounded-full border border-white/15 bg-white/5 px-5 py-2.5 text-sm font-medium text-eskan-ivory transition-all duration-300 hover:border-gold/40 hover:bg-gold/10 hover:text-gold-muted"
        >
          <Icon name="instagram" class="h-4 w-4" />
          @sangeskan
        </a>
      </div>
    </div>

    <div class="mt-14 rounded-2xl border border-white/10 py-6 text-center text-xs text-white/40">
      © {year} {t.siteName}. {t.footer.rights}.
    </div>
  </div>
</footer>
