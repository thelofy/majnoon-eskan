---
import Icon from '@/components/icons/Icon.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  location?: string;
  year?: string;
  ctaLabel: string;
}

const { href, title, description, image, imageAlt, location, year, ctaLabel } = Astro.props;
const meta = [location, year].filter(Boolean).join(' · ');
---

<article class="group luxury-card">
  <a href={href} class="block">
    <div class="relative aspect-[3/4] overflow-hidden sm:aspect-[4/5]">
      <img
        src={image}
        alt={imageAlt}
        loading="lazy"
        decoding="async"
        width="800"
        height="1000"
        class="image-zoom h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent transition-opacity duration-luxury group-hover:via-black/50" />
      <div class="absolute inset-x-0 bottom-0 p-6 md:p-8">
        {meta && (
          <p class="text-[0.65rem] font-normal tracking-wide text-white/40">{meta}</p>
        )}
        <h3 class="mt-1.5 font-display text-2xl font-bold leading-tight text-white md:text-3xl">{title}</h3>
        <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-white/55">{description}</p>
        <span class="mt-5 inline-flex items-center gap-2 text-[0.65rem] font-semibold uppercase tracking-luxury text-gold-champagne transition-all duration-luxury ease-luxury group-hover:gap-3 group-hover:text-gold-light">
          {ctaLabel}
          <Icon name="arrow" class="h-3.5 w-3.5 transition-transform duration-luxury ease-luxury group-hover:translate-x-1 rtl:rotate-180 rtl:group-hover:-translate-x-1" />
        </span>
      </div>
    </div>
  </a>
</article>
