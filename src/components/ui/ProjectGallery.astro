---
interface Props {
  images: string[];
  title: string;
  location: string;
}

const { images, title, location } = Astro.props;

const pad = (n: number) => String(n + 1).padStart(2, '0');

function cellClass(i: number, total: number) {
  if (i === 0) return 'col-span-2 aspect-[16/10]';
  if (i === 3 && total > 4) return 'col-span-2 aspect-[16/9]';
  return 'aspect-square';
}
---

<div class="grid grid-cols-2 gap-3 md:gap-4">
  {images.map((img, i) => (
    <div class={`group relative overflow-hidden rounded-3xl bg-eskan-warm ${cellClass(i, images.length)}`}>
      <img
        src={img}
        alt={`${title} — gallery image ${i + 1} in ${location}`}
        loading="lazy"
        class="image-zoom h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-eskan-base/0 transition-colors duration-300 group-hover:bg-eskan-base/10" />
      <span class="absolute start-4 top-4 flex h-9 w-9 items-center justify-center rounded-xl bg-white/90 font-mono text-xs font-medium text-eskan-charcoal shadow-card backdrop-blur-sm">
        {pad(i)}
      </span>
    </div>
  ))}
</div>
