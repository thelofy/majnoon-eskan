---
import type { IconName } from './types';
import { iconPaths } from './paths';

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: className = 'h-6 w-6' } = Astro.props;
---

<svg
  class:list={[className, 'shrink-0']}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.25"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d={iconPaths[name]} />
</svg>
