---
import Icon from '@/components/icons/Icon.astro';
import type { IconName } from '@/components/icons/types';

interface Stat {
  value: string;
  label: string;
  description?: string;
  icon: IconName;
}

interface Props {
  stats: Stat[];
  variant?: 'dark' | 'light';
}

const { stats, variant = 'dark' } = Astro.props;
const isLight = variant === 'light';
---

<section class:list={['editorial-container', isLight ? 'py-12 md:py-16' : 'py-10 md:py-14']}>
  <div class:list={['stat-dashboard', isLight && 'border-eskan-sand/60 bg-eskan-cream/90']}>
    <div class="grid grid-cols-2 md:grid-cols-4">
      {stats.map((stat, i) => (
        <div
          class:list={[
            'group relative flex flex-col gap-2 px-6 py-8 transition-all duration-luxury ease-luxury md:px-8 md:py-10',
            i < stats.length - 1 && 'md:border-e md:border-gold/10',
            i % 2 === 0 && 'border-e border-gold/10 md:border-e',
            i < 2 && 'border-b border-gold/10 md:border-b-0',
          ]}
        >
          <div class="mb-2 flex items-center gap-3">
            <div class:list={['flex h-9 w-9 items-center justify-center rounded-lg border', isLight ? 'border-gold/20 bg-gold/5' : 'border-gold/15 bg-gold/10']}>
              <Icon name={stat.icon} class="h-4 w-4 text-gold" />
            </div>
            <span class:list={['text-[0.6rem] font-semibold uppercase tracking-luxury', isLight ? 'text-eskan-muted' : 'text-gold-muted/80']}>
              {stat.label}
            </span>
          </div>
          <p class:list={['font-display text-3xl font-semibold tracking-tight md:text-4xl', isLight ? 'text-eskan-ink' : 'text-eskan-ivory']}>
            {stat.value}
          </p>
          {stat.description && (
            <p class:list={['mt-1 text-xs leading-relaxed', isLight ? 'text-eskan-muted' : 'text-eskan-ivory/35']}>
              {stat.description}
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
