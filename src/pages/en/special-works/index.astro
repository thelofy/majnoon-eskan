---
import Layout from '@/layouts/Layout.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import ProjectCard from '@/components/ui/ProjectCard.astro';
import { getDictionary } from '@/i18n/utils';
import { getSpecialWorksByLocale } from '@/lib/content';
import { entrySlug } from '@/lib/content';

const locale = 'en';
const t = getDictionary(locale);
const pathname = Astro.url.pathname;
const works = await getSpecialWorksByLocale(locale);
const base = `/${locale}`;
---

<Layout locale={locale} title={t.nav.specialWorks} description={t.sections.specialWorks} pathname={pathname}>
  <section class="editorial-container py-16 md:py-24">
    <SectionHeader title={t.nav.specialWorks} />
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {works.map((work) => (
        <ProjectCard
          href={`${base}/special-works/${entrySlug(work.id)}`}
          title={work.data.title}
          description={work.data.description}
          image={work.data.heroImage}
          imageAlt={`${work.data.title} — special stonework by Eskan Stone`}
          location={work.data.location}
          year={work.data.year}
          ctaLabel={t.project.viewProject}
        />
      ))}
    </div>
  </section>
</Layout>
