---
import Layout from '@/layouts/Layout.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Button from '@/components/ui/Button.astro';
import { getDictionary } from '@/i18n/utils';

const locale = 'en';
const t = getDictionary(locale);
const pathname = Astro.url.pathname;
---

<Layout locale={locale} title={t.contact.title} description={t.contact.subtitle} pathname={pathname}>
  <section class="editorial-container py-16 md:py-24">
    <SectionHeader title={t.contact.title} subtitle={t.contact.subtitle} />
    <div class="grid gap-16 lg:grid-cols-2">
      <form class="space-y-6" action="#" method="post">
        <div>
          <label for="name" class="text-xs uppercase tracking-luxury text-eskan-muted">{t.contact.name}</label>
          <input type="text" id="name" name="name" required class="input-dark" />
        </div>
        <div>
          <label for="email" class="text-xs uppercase tracking-luxury text-eskan-muted">{t.contact.email}</label>
          <input type="email" id="email" name="email" required class="input-dark" />
        </div>
        <div>
          <label for="phone" class="text-xs uppercase tracking-luxury text-eskan-muted">{t.contact.phone}</label>
          <input type="tel" id="phone" name="phone" class="input-dark" />
        </div>
        <div>
          <label for="message" class="text-xs uppercase tracking-luxury text-eskan-muted">{t.contact.message}</label>
          <textarea id="message" name="message" rows="5" required class="input-dark" />
        </div>
        <Button type="submit" variant="primary">{t.contact.submit}</Button>
      </form>
      <div>
        <p class="font-display text-xl text-eskan-ivory">{t.contact.factory}</p>
        <p class="mt-4 text-eskan-muted">{t.contact.address}</p>
        <img
          src="/assets/factory/hero-factory.jpg"
          alt="Eskan Stone production factory exterior in Yazd"
          loading="lazy"
          class="mt-8 aspect-[4/3] w-full object-cover"
        />
      </div>
    </div>
  </section>
</Layout>
